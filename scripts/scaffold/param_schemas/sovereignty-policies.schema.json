{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "sovereignty-policies.params",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "deployConfidential": { "type": "boolean", "default": true },
    "deployGlobal": { "type": "boolean", "default": true },
    "enforcementMode": { "type": "string", "enum": ["Default", "DoNotEnforce"], "default": "Default" },
    "listOfAllowedLocations": { "type": "array", "items": { "type": "string" }, "default": [] }
  }
}
