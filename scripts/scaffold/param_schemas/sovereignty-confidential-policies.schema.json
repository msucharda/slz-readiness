{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "sovereignty-confidential-policies.params",
  "type": "object",
  "additionalProperties": false,
  "required": ["listOfAllowedLocations"],
  "properties": {
    "enforcementMode": { "type": "string", "enum": ["Default", "DoNotEnforce"], "default": "Default" },
    "rolloutPhase": { "type": "string", "enum": ["audit", "enforce"], "default": "audit" },
    "listOfAllowedLocations": { "type": "array", "items": { "type": "string" } }
  }
}
