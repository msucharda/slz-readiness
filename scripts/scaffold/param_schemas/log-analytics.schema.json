{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "log-analytics.params",
  "type": "object",
  "additionalProperties": false,
  "required": ["workspaceName"],
  "properties": {
    "workspaceName": { "type": "string", "minLength": 4, "maxLength": 63 },
    "location": { "type": "string" },
    "retentionInDays": { "type": "integer", "minimum": 30, "maximum": 730, "default": 365 },
    "skuName": { "type": "string", "enum": ["PerGB2018", "CapacityReservation"], "default": "PerGB2018" }
  }
}
